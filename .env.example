# Copy this file to .env (same folder as docker-compose.yml) and fill in
# your actual values. docker-compose loads .env automatically - you don't
# need to source it yourself.

# Plex library root. Used as both the host path and the in-container path
# (identity-mounted - see the comment in docker-compose.yml for why).
LIBRARY_ROOT=/mnt/user/media/bike-racing

# Host path to the SAME share Transmission's own container maps to
# /downloads internally (check Transmission's Docker template path mappings
# in the Unraid UI to confirm - look for whatever host path maps to
# /downloads there). This is the whole share Transmission was given, not
# just the "complete" subfolder, since TR_TORRENT_DIR will report paths
# like /downloads/complete/... and this needs to resolve the same way here.
DOWNLOADS_DIR=/mnt/user/downloads

# Port the archiver listens on, and the port published on TOWER's network.
# This is the port you'll use in torrent-done.env's ARCHIVER_URL.
PORT=8420

# Optional. /webhook/torrent-done has no other authentication (it's meant
# to be called only by Transmission's own hook script, trusted implicitly
# on a LAN); set this if that route is ever reachable from outside your
# LAN (a reverse proxy, a Cloudflare Tunnel, etc), and set the matching
# WEBHOOK_SECRET in torrent-done.env too. Same one-time-seed-then-Settings-
# tab-is-authoritative rule as the integrations below applies here; this is
# also settable/rotatable live from the web UI's Settings tab afterward.
# Leave unset to keep the original open behavior.

# WEBHOOK_SECRET=

# Path to config/events.json as seen INSIDE the container. Rarely needs to change.
CONFIG_CONTAINER_PATH=/app/config/events.json

# Path to config/settings.json (Plex/Discord/hot-folder settings) as seen
# INSIDE the container. Rarely needs to change.
SETTINGS_CONTAINER_PATH=/app/config/settings.json

# Path to config/activity.json (the Home tab's recent-activity log) as seen
# INSIDE the container. Rarely needs to change.
ACTIVITY_CONTAINER_PATH=/app/config/activity.json

# --- Optional: Plex/Discord/hot-folder settings below are a ONE-TIME SEED
# ONLY. The first time config/settings.json doesn't exist yet, it's created
# from whatever's set here; after that the file is authoritative and these
# env vars are ignored on every later boot - use the web UI's Settings panel
# (WEBUI_PASSWORD below) to change any of them live from then on, no restart
# needed. Delete config/settings.json if you want these env vars to reseed
# it fresh instead. ---

# --- Plex partial-scan integration ---
# Leave these unset to disable - nothing else changes. When all three of
# PLEX_URL/PLEX_TOKEN/PLEX_SECTION_ID are set, the archiver tells Plex to
# rescan just the one season folder that changed after each successful
# copy (not the whole racing library, and not any of your other Plex
# libraries). See the README's "Plex integration" section for how to find
# your token and section id.

# PLEX_URL=http://192.168.1.10:32400
# PLEX_TOKEN=
# PLEX_SECTION_ID=

# The Plex library root, as PLEX'S OWN container/process sees it - only
# needed if that differs from LIBRARY_ROOT above (e.g. if Plex runs in its
# own Docker container with a different internal mount point for the same
# host share, the same situation as Transmission's /downloads mapping).
# Leave unset if Plex sees the exact same path as this container does.
# PLEX_LIBRARY_ROOT=/mnt/user/media/bike-racing

# --- Optional: hot-folder ingestion (bypass Transmission) ---
# Leave HOTFOLDER_DIR unset to disable - nothing else changes. When set,
# the archiver watches this folder (a subfolder of DOWNLOADS_DIR, sibling to
# Transmission's "complete" folder - created automatically on first use if
# it doesn't already exist) for manually-dropped files/folders and runs them
# through the exact same processing as a completed torrent. Once a drop's
# size/mtime has been unchanged for HOTFOLDER_STABLE_POLLS consecutive polls
# (each HOTFOLDER_POLL_INTERVAL_MS apart), it's processed and the original
# is moved into HOTFOLDER_DIR's "processed" subfolder - never deleted. See
# the README's "hot-folder ingestion" section, and the comment in
# docker-compose.yml explaining why this needs its own read-write mount
# even though DOWNLOADS_DIR above is mounted read-only.

# HOTFOLDER_DIR=/downloads/domestique
# HOTFOLDER_POLL_INTERVAL_MS=60000
# HOTFOLDER_STABLE_POLLS=3

# --- Optional: Discord notifications ---
# Leave DISCORD_WEBHOOK_URL unset to disable - nothing else changes. When
# set, the archiver posts one message per torrent-done event (whether from
# the Transmission webhook or hot-folder ingestion) summarizing what was
# archived/skipped, plus any auto-created shows, quality/upgrade warnings,
# alternate-version tags, or errors. See the README's "Discord notifications"
# section for how to create a webhook.

# DISCORD_WEBHOOK_URL=

# Optional: a Discord user id (right-click a user with Developer Mode on,
# "Copy User ID") to @mention only on review-worthy notifications (the
# warnings/errors above) - routine successful archives post without a
# mention either way. Leave unset to have everything post without a mention.
# DISCORD_MENTION_USER_ID=

# --- Optional: web UI (config editor, match tester, activity log) ---
# Leave WEBUI_PASSWORD unset to disable the web UI entirely - unlike the
# integrations above, this one fails CLOSED (its /ui and /api/* routes
# respond 503) rather than open, since it exposes read/write config access
# over HTTP. Once set, browse to http://<TOWER-IP>:8420/ui - your browser
# will prompt for credentials (HTTP Basic Auth).

# WEBUI_PASSWORD=

# Optional: also require this exact username (checked alongside the
# password above). Leave unset to accept any username, checking only the
# password. See the README's "web UI" section for details.
# WEBUI_USER=

# --- Optional: run the container as a non-root user (recommended) ---
# linuxserver.io-style PUID/PGID: set both and the container drops from
# root to this user/group at startup, after fixing ownership on the two
# bind-mounted config files (events.json/settings.json) automatically. On
# Unraid, 99/100 is the usual nobody:users pair that Transmission and most
# other containers already use. Leave both unset to keep running as root
# (the original behavior).
#
# BEFORE enabling on an EXISTING install: files the app created while it
# ran as root are root-owned, so the new user can't write near them. Run
# once on the host (with your real paths and ids):
#   chown -R 99:100 /mnt/user/media/bike-racing        # your LIBRARY_ROOT
#   chown -R 99:100 /mnt/user/downloads/domestique     # hot-folder, if used
# The read-only /downloads mount needs no ownership change (read is enough).

# PUID=99
# PGID=100
