# Copy this file to .env (same folder as docker-compose.yml) and fill in
# your actual values. docker-compose loads .env automatically — you don't
# need to source it yourself.

# Plex library root. Used as both the host path and the in-container path
# (identity-mounted — see the comment in docker-compose.yml for why).
LIBRARY_ROOT=/mnt/user/towerMEDIAracing/2021_plex_library

# Host path to the SAME share Transmission's own container maps to
# /downloads internally (check Transmission's Docker template path mappings
# in the Unraid UI to confirm — look for whatever host path maps to
# /downloads there). This is the whole share Transmission was given, not
# just the "complete" subfolder, since TR_TORRENT_DIR will report paths
# like /downloads/complete/... and this needs to resolve the same way here.
DOWNLOADS_DIR=/mnt/user/fastARCHIVE-seeding

# Port the archiver listens on, and the port published on TOWER's network.
# This is the port you'll use in torrent-done.env's ARCHIVER_URL.
PORT=8420

# Path to config/shows.json as seen INSIDE the container. Rarely needs to change.
CONFIG_CONTAINER_PATH=/app/config/shows.json
