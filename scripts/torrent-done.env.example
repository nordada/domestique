# Copy this file to torrent-done.env, in the SAME folder as torrent-done.sh
# (that's important - the script looks for a file named exactly
# "torrent-done.env" sitting next to itself).
#
# Since Transmission and Domestique are separate Docker containers not on
# the same Docker network, "http://domestique:8420/..." won't resolve from
# inside Transmission's container - use TOWER's actual LAN IP instead, and
# the same PORT you set in Domestique's own .env file.

ARCHIVER_URL=http://192.168.1.xx:8420/webhook/torrent-done

# Optional. Only needed if Domestique's own WEBHOOK_SECRET (or the
# Settings tab's "Webhook security" field) is set, which it should be if
# this webhook is ever reachable from outside your LAN (a reverse proxy,
# a Cloudflare Tunnel, etc). Must match exactly, or the webhook rejects
# the request with 401. Leave both unset to keep the original behavior:
# no secret required.
WEBHOOK_SECRET=
