#!/usr/bin/env bash
# Copy this to deploy-to-tower.sh (gitignored - it embeds your own server's
# address, and is deliberately not committed) and fill in your own values.
#
# Syncs the local repo to your server's Domestique appdata folder. Run from
# the repo root (or anywhere - use an absolute path below). Excludes
# node_modules, dist, and .git (the server doesn't need a working git
# checkout, just the files).
#
# After this finishes, on the server: cd into the deployed folder and run
# `docker compose up -d` (add --build if source files changed, not just
# config) to pick up the changes.
set -euo pipefail

# --chmod=ugo+rX: rsync -a preserves source permissions, and a file that's
# 600 on the dev machine (easy to end up with, e.g. anything copied out of
# a download or another user's folder) would land unreadable by the
# container's non-root PUID user on the server. Granting read (and
# directory-traversal x) to everyone on transfer prevents that without
# stripping any executable bits.
#
# --exclude 'config/events.json': your server's copy is the live, user-edited
# race list (grown via the web UI and auto-create, not the repo's shipped
# starter default) - it should only ever be seeded once on first boot, same
# as settings.json/activity.json, never overwritten by a code deploy.
rsync -av \
  --chmod=ugo+rX \
  --exclude 'node_modules' \
  --exclude 'dist' \
  --exclude '.git' \
  --exclude '.DS_Store' \
  --exclude '.claude' \
  --exclude 'config/events.json' \
  ~/projects/domestique/ user@YOUR-SERVER-IP:/path/to/domestique/
